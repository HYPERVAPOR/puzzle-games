# 用户口令（默认letmein）
GAME_PASSCODE=letmein

# 管理员口令
ADMIN_PASSCODE=admin123

# 默认房间房主密码（用于成为默认房间的房主）
DEFAULT_ROOM_OWNER_PASSWORD=owner123

# OpenRouter API配置
# 获取API密钥：https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini
OPENROUTER_GENERATE_MODEL=google/gemini-2.0-flash-thinking-exp:free

# AI温度参数（0.0-2.0，值越高输出越随机，越低越确定）
OPENROUTER_JUDGE_TEMPERATURE=0.7
OPENROUTER_GENERATE_TEMPERATURE=0.7

# AI推理模式开关（独立控制）
# 判定AI推理模式：启用后判定会更准确，但响应速度变慢
ENABLE_JUDGE_REASONING=false
# 生成AI推理模式：启用后生成的题目质量更高，但生成速度变慢
ENABLE_GENERATE_REASONING=false

# JWT密钥（请修改为随机字符串）
JWT_SECRET=change-this-to-a-secure-random-string

# 数据存储路径
DATA_PATH=./data
